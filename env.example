# ── S.T.A.R. UNIT 7 — ENVIRONMENT CONFIG ─────────────────
# Copy this file to .env and fill in your values.
# chmod 600 .env  ← run this after saving

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Port the Flask server listens on (access via http://127.0.0.1:7823)
STAR_PORT=7823

# Where task data is stored (relative to star_server.py, or absolute path)
STAR_TASKS_FILE=tasks.json
STAR_NOTIF_FILE=notifications.json

# How often the daemon checks for overdue tasks (seconds)
# 900 = 15 minutes
STAR_CHECK_INTERVAL=900

# Maximum follow-up escalation contacts before going silent
STAR_MAX_ESCALATIONS=4

# How often to re-escalate a follow-up task (seconds, default same as CHECK_INTERVAL)
STAR_ESCALATION_INTERVAL=900

# Telegram Bot API token (from @BotFather)
STAR_TELEGRAM_TOKEN=

# Telegram chat ID to send alerts to (your private chat with the bot, or a group)
# Get it by messaging the bot and calling: https://api.telegram.org/bot<TOKEN>/getUpdates
STAR_TELEGRAM_CHAT_ID=
